# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TELEGRAM_BOT_TOKEN: The token for your Telegram bot from @BotFather
TELEGRAM_BOT_TOKEN=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# FIREBASE_PROJECT_ID: Optional override for Firebase project ID on custom hosting (e.g. Railway)
FIREBASE_PROJECT_ID=""

# FIREBASE_DATABASE_ID: Optional override for Firestore database ID
FIREBASE_DATABASE_ID=""

# FIREBASE_SERVICE_ACCOUNT: Optional JSON string of your Google Service Account keys for custom Firestore databases
FIREBASE_SERVICE_ACCOUNT=""

